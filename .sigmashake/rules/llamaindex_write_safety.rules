# llamaindex_write_safety.rules
# Technology: llamaindex | Capability: write

rule llamaindex-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_llamaindex_PATTERN"
  MESSAGE "Blocked an unsafe pattern in llamaindex. Use the recommended best practices for 2025/2026."
}

rule llamaindex-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_llamaindex_API"
  MESSAGE "You are using an outdated API for llamaindex. Please upgrade to the newer API."
}
